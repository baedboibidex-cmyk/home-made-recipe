    <script>
        // DOM Elements
        const ageModal = document.getElementById('ageModal');
        const loginModal = document.getElementById('loginModal');
        const premiumModal = document.getElementById('premiumModal');
        const userProfile = document.getElementById('userProfile');
        const dropdownMenu = document.getElementById('dropdownMenu');
        const premiumBtn = document.getElementById('premiumBtn');
        const bannerPremiumBtn = document.getElementById('bannerPremiumBtn');
        const premiumStatus = document.getElementById('premiumStatus');
        const logoutBtn = document.getElementById('logoutBtn');
        const savedRecipes = document.getElementById('savedRecipes');
        const myAccount = document.getElementById('myAccount');
        const subscribeBtn = document.getElementById('subscribeBtn');
        const searchInput = document.getElementById('searchInput');
        const featuredSave = document.getElementById('featuredSave');
        const startCooking = document.getElementById('startCooking');
        const shareRecipe = document.getElementById('shareRecipe');
        
        // Initialize app on load
        document.addEventListener('DOMContentLoaded', initApp);
        
        function initApp() {
            // Setup event listeners
            setupEventListeners();
            
            // Check age verification
            if (!localStorage.getItem('ageVerified')) {
                ageModal.classList.add('active');
            } else {
                // Check login status
                if (localStorage.getItem('userLoggedIn') === 'true') {
                    const email = localStorage.getItem('userEmail');
                    userProfile.textContent = email.charAt(0).toUpperCase();
                    dropdownMenu.classList.add('active');
                    updatePremiumStatus();
                } else {
                    // Show login after 2 seconds if not logged in and age verified
                    setTimeout(() => {
                        if (!document.querySelector('.modal.active') && localStorage.getItem('ageVerified')) {
                            loginModal.classList.add('active');
                        }
                    }, 2000);
                }
            }
        }
        
        function setupEventListeners() {
            // Age Verification
            document.getElementById('ageYes').addEventListener('click', () => {
                localStorage.setItem('ageVerified', 'true');
                ageModal.classList.remove('active');
                showNotification('✓ Age verified! Welcome to Home Made Recipe');
                
                // Show login prompt after age verification
                setTimeout(() => {
                    if (!localStorage.getItem('userLoggedIn')) {
                        showNotification('Please log in to access all features');
                        loginModal.classList.add('active');
                    }
                }, 1500);
            });
            
            document.getElementById('ageNo').addEventListener('click', () => {
                showNotification('❌ You must be 18+ to use this app. Redirecting...');
                setTimeout(() => {
                    window.location.href = 'https://www.google.com';
                }, 2000);
            });
            
            document.getElementById('ageClose').addEventListener('click', (e) => {
                e.preventDefault();
                showNotification('❌ Age verification required to continue');
            });
            
            // Login/Signup
            document.getElementById('loginSubmit').addEventListener('click', handleLogin);
            document.getElementById('signupSubmit').addEventListener('click', handleSignup);
            document.getElementById('loginClose').addEventListener('click', () => loginModal.classList.remove('active'));
            document.getElementById('switchToSignup').addEventListener('click', switchToSignup);
            
            // Premium
            premiumBtn.addEventListener('click', handlePremiumClick);
            bannerPremiumBtn.addEventListener('click', () => premiumModal.classList.add('active'));
            subscribeBtn.addEventListener('click', handleSubscription);
            document.getElementById('premiumClose').addEventListener('click', () => premiumModal.classList.remove('active'));
            
            // User Profile
            userProfile.addEventListener('click', toggleDropdown);
            logoutBtn.addEventListener('click', handleLogout);
            savedRecipes.addEventListener('click', (e) => {
                e.preventDefault();
                showNotification('📚 Showing your saved recipes...');
            });
            myAccount.addEventListener('click', (e) => {
                e.preventDefault();
                showAccountInfo();
            });
            
            // Recipe Actions
            document.querySelectorAll('.save-btn').forEach(btn => {
                btn.addEventListener('click', toggleSaveRecipe);
            });
            
            document.querySelectorAll('.view-recipe').forEach(btn => {
                btn.addEventListener('click', viewRecipe);
            });
            
            document.querySelectorAll('.premium-action').forEach(btn => {
                btn.addEventListener('click', handlePremiumRecipe);
            });
            
            // Category Selection
            document.querySelectorAll('.category-card').forEach(card => {
                card.addEventListener('click', selectCategory);
            });
            
            // Search
            searchInput.addEventListener('input', handleSearch);
            
            // Featured Recipe Actions
            featuredSave.addEventListener('click', toggleFeaturedSave);
            startCooking.addEventListener('click', () => showNotification('👨‍🍳 Starting your cooking timer for Creamy Mushroom Risotto!'));
            shareRecipe.addEventListener('click', () => showNotification('📤 Recipe shared successfully!'));
            
            // Close dropdown when clicking outside
            document.addEventListener('click', (e) => {
                if (!userProfile.contains(e.target) && !dropdownMenu.contains(e.target) && dropdownMenu.classList.contains('active')) {
                    dropdownMenu.classList.remove('active');
                }
            });
        }
        
        function handleLogin() {
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            
            if (email && password) {
                // Simulate login
                localStorage.setItem('userLoggedIn', 'true');
                localStorage.setItem('userEmail', email);
                if (!localStorage.getItem('isPremium')) {
                    localStorage.setItem('isPremium', 'false');
                }
                
                // Set user initial
                userProfile.textContent = email.charAt(0).toUpperCase();
                
                loginModal.classList.remove('active');
                dropdownMenu.classList.add('active');
                updatePremiumStatus();
                showNotification(`✓ Welcome back, ${email.split('@')[0]}!`);
            } else {
                showNotification('❌ Please fill in all fields');
            }
        }
        
        function handleSignup() {
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            
            if (email && password && password.length >= 6) {
                // Simulate signup
                localStorage.setItem('userLoggedIn', 'true');
                localStorage.setItem('userEmail', email);
                localStorage.setItem('isPremium', 'false'); // Default free account
                localStorage.setItem('savedRecipes', JSON.stringify(['carbonara'])); // Default saved recipe
                
                // Set user initial
                userProfile.textContent = email.charAt(0).toUpperCase();
                
                loginModal.classList.remove('active');
                dropdownMenu.classList.add('active');
                updatePremiumStatus();
                showNotification(`✓ Account created for ${email.split('@')[0]}! Start cooking!`);
            } else {
                showNotification('❌ Password must be at least 6 characters');
            }
        }
        
        function switchToSignup() {
            document.getElementById('authTitle').textContent = 'Create New Account';
            document.getElementById('loginSubmit').style.display = 'none';
            document.getElementById('signupSubmit').style.display = 'block';
        }
        
        function handlePremiumClick() {
            if (localStorage.getItem('userLoggedIn') !== 'true') {
                showNotification('❌ Please log in first to access Premium features');
                loginModal.classList.add('active');
                return;
            }
            
            if (localStorage.getItem('isPremium') === 'true') {
                showNotification('✨ You already have Premium access!');
                return;
            }
            
            premiumModal.classList.add('active');
        }
        
        function handleSubscription() {
            // Simulate subscription
            localStorage.setItem('isPremium', 'true');
            localStorage.setItem('premiumExpiry', new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString()); // 7-day trial
            
            premiumModal.classList.remove('active');
            updatePremiumStatus();
            unlockPremiumContent();
            showNotification('✨ Welcome to Premium! 7-day free trial activated');
        }
        
        function handleLogout() {
            localStorage.removeItem('userLoggedIn');
            localStorage.removeItem('userEmail');
            localStorage.removeItem('isPremium');
            localStorage.removeItem('premiumExpiry');
            dropdownMenu.classList.remove('active');
            userProfile.textContent = 'HR';
            premiumStatus.textContent = 'Free Account';
            document.getElementById('premiumBtn').disabled = false;
            document.getElementById('premiumBtn').innerHTML = '<i class="fas fa-crown"></i> Go Premium';
            lockPremiumContent();
            showNotification('✓ Successfully logged out');
        }
        
        function toggleSaveRecipe(e) {
            const btn = e.currentTarget;
            const recipeId = btn.getAttribute('data-recipe');
            btn.classList.toggle('active');
            
            // Update icon
            const icon = btn.querySelector('i');
            if (btn.classList.contains('active')) {
                icon.classList.remove('far');
                icon.classList.add('fas');
                saveRecipe(recipeId);
                showNotification(`✅ "${getRecipeName(recipeId)}" saved to your collection!`);
            } else {
                icon.classList.remove('fas');
                icon.classList.add('far');
                unsaveRecipe(recipeId);
                showNotification(`❌ "${getRecipeName(recipeId)}" removed from your collection`);
            }
        }
        
        function toggleFeaturedSave() {
            featuredSave.classList.toggle('active');
            const icon = featuredSave.querySelector('i');
            if (featuredSave.classList.contains('active')) {
                icon.classList.add('fas');
                saveRecipe('featured');
                showNotification('✅ "Creamy Mushroom Risotto" saved to your collection!');
            } else {
                icon.classList.remove('fas');
                unsaveRecipe('featured');
                showNotification('❌ "Creamy Mushroom Risotto" removed from your collection');
            }
        }
        
        function saveRecipe(recipeId) {
            let saved = JSON.parse(localStorage.getItem('savedRecipes') || '[]');
            if (!saved.includes(recipeId)) {
                saved.push(recipeId);
                localStorage.setItem('savedRecipes', JSON.stringify(saved));
            }
        }
        
        function unsaveRecipe(recipeId) {
            let saved = JSON.parse(localStorage.getItem('savedRecipes') || '[]');
            saved = saved.filter(id => id !== recipeId);
            localStorage.setItem('savedRecipes', JSON.stringify(saved));
        }
        
        function getRecipeName(id) {
            const names = {
                'avocado-toast': 'Avocado Toast with Poached Eggs',
                'carbonara': 'Classic Spaghetti Carbonara',
                'salmon': 'Grilled Salmon with Lemon Dill Sauce',
                'thai-curry': 'Authentic Thai Green Curry',
                'ramen': 'Japanese Ramen (Tonkotsu)',
                'souffle': 'French Soufflé Masterclass',
                'featured': 'Creamy Mushroom Risotto'
            };
            return names[id] || id;
        }
        
        function viewRecipe(e) {
            const recipeId = e.currentTarget.getAttribute('data-recipe');
            showNotification(`👨‍🍳 Opening "${getRecipeName(recipeId)}" recipe...`);
            document.getElementById('featured-recipe').scrollIntoView({ behavior: 'smooth' });
        }
        
        function handlePremiumRecipe(e) {
            e.preventDefault();
            if (localStorage.getItem('isPremium') === 'true') {
                const recipeId = e.currentTarget.closest('.recipe-card').getAttribute('data-recipe');
                showNotification(`✨ Enjoy your premium recipe: "${getRecipeName(recipeId)}"!`);
            } else {
                showNotification('🔒 Premium content requires subscription');
                premiumModal.classList.add('active');
            }
        }
        
        function selectCategory(e) {
            const category = e.currentTarget.getAttribute('data-category');
            
            // Update active state
            document.querySelectorAll('.category-card').forEach(card => {
                card.classList.remove('active');
            });
            e.currentTarget.classList.add('active');
            
            // Check if premium category
            if (e.currentTarget.classList.contains('premium') && localStorage.getItem('isPremium') !== 'true') {
                showNotification(`🔒 "${e.currentTarget.querySelector('div').textContent}" recipes require Premium`);
                premiumModal.classList.add('active');
                return;
            }
            
            showNotification(`✅ Showing ${e.currentTarget.querySelector('div').textContent} recipes`);
        }
        
        function handleSearch(e) {
            const searchTerm = e.target.value.toLowerCase().trim();
            if (searchTerm.length > 2) {
                showNotification(`🔍 Searching for "${searchTerm}"...`);
            }
        }
        
        function toggleDropdown() {
            if (localStorage.getItem('userLoggedIn') === 'true') {
                dropdownMenu.classList.toggle('active');
            } else {
                loginModal.classList.add('active');
            }
        }
        
        function showAccountInfo() {
            if (localStorage.getItem('isPremium') === 'true') {
                const expiry = new Date(localStorage.getItem('premiumExpiry'));
                showNotification(`👑 Premium Account\nTrial expires: ${expiry.toLocaleDateString()}`);
            } else {
                showNotification(`👤 Free Account\nUpgrade to Premium for international recipes & advanced techniques`);
            }
        }
        
        function updatePremiumStatus() {
            if (localStorage.getItem('isPremium') === 'true') {
                premiumStatus.innerHTML = '<i class="fas fa-crown"></i> Premium Member';
                document.getElementById('premiumBtn').innerHTML = '<i class="fas fa-check"></i> Premium Active';
                document.getElementById('premiumBtn').disabled = true;
            } else {
                premiumStatus.innerHTML = '<i class="fas fa-user"></i> Free Account';
                document.getElementById('premiumBtn').disabled = false;
                document.getElementById('premiumBtn').innerHTML = '<i class="fas fa-crown"></i> Go Premium';
            }
        }
        
        function unlockPremiumContent() {
            // Unlock premium recipe buttons
            document.querySelectorAll('.recipe-card.premium .premium-action').forEach(btn => {
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-eye"></i> View Recipe';
                btn.classList.remove('btn-premium');
                btn.classList.add('btn-primary');
                btn.removeEventListener('click', handlePremiumRecipe);
                btn.addEventListener('click', (e) => {
                    const recipeId = e.currentTarget.closest('.recipe-card').getAttribute('data-recipe');
                    showNotification(`✨ Enjoy your premium recipe: "${getRecipeName(recipeId)}"!`);
                });
            });
            
            // Hide lock icons
            document.querySelectorAll('.premium-lock').forEach(lock => {
                lock.style.display = 'none';
            });
            
            // Enable premium categories
            document.querySelectorAll('.category-card.premium').forEach(card => {
                card.style.opacity = '1';
                card.style.cursor = 'pointer';
            });
        }
        
        function lockPremiumContent() {
            // Lock premium recipe buttons
            document.querySelectorAll('.recipe-card.premium .premium-action').forEach(btn => {
                btn.disabled = true;
                btn.innerHTML = '<i class="fas fa-lock"></i> Premium';
                btn.classList.add('btn-premium');
                btn.classList.remove('btn-primary');
                btn.removeEventListener('click', handlePremiumRecipe);
                btn.addEventListener('click', handlePremiumRecipe);
            });
            
            // Show lock icons
            document.querySelectorAll('.premium-lock').forEach(lock => {
                lock.style.display = 'flex';
            });
            
            // Disable premium categories
            document.querySelectorAll('.category-card.premium').forEach(card => {
                card.style.opacity = '0.6';
                card.style.cursor = 'not-allowed';
            });
        }
        
        function showNotification(message) {
            // Remove existing notifications
            const existing = document.querySelector('.notification');
            if (existing) existing.remove();
            
            // Create notification element
            const notification = document.createElement('div');
            notification.className = 'notification';
            notification.innerHTML = message.replace(/\n/g, '<br>');
            
            // Add to body
            document.body.appendChild(notification);
            
            // Auto-remove after animation
            setTimeout(() => {
                if (notification.parentNode) {
                    notification.remove();
                }
            }, 3000);
        }
    </script>
</body>
</html>